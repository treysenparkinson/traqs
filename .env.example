# ──────────────────────────────────────────────────────
# TRAQS Environment Variables — copy to .env.local
# Never commit .env or .env.local (they are in .gitignore)
# ──────────────────────────────────────────────────────

# Auth0 Single Page Application settings
# Found in: Auth0 Dashboard → Applications → TRAQS → Settings
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_spa_client_id
VITE_AUTH0_AUDIENCE=https://traqs.matrixsystems.com/api

# ──────────────────────────────────────────────────────
# Backend secrets — set in Netlify Dashboard (never prefix with VITE_)
# Also add to a local .env file for `netlify dev`
# ──────────────────────────────────────────────────────
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_AUDIENCE=https://traqs.matrixsystems.com/api
# ANTHROPIC_API_KEY=sk-ant-...
# S3_BUCKET=matrix-systems-traqs
# MY_AWS_REGION=us-east-1
# MY_AWS_ACCESS_KEY_ID=AKIA...
# MY_AWS_SECRET_ACCESS_KEY=...
# ONESIGNAL_APP_ID=...
# ONESIGNAL_API_KEY=os_v2_app_...
# SES sender (must be a verified identity in AWS SES). Falls back to no-reply@traqs.app.
# SEND_FROM_EMAIL=no-reply@traqs.matrixsystems.com

# ──────────────────────────────────────────────────────
# Security / feature flags
# ──────────────────────────────────────────────────────
# Origin (or comma-separated list) the Netlify functions and edge function
# accept CORS requests from. Defaults to https://traqs.matrixsystems.com.
# ALLOWED_ORIGIN=https://traqs.matrixsystems.com

# Set to "true" to allow public org self-signup via POST /org. Default
# (unset / anything else) returns 403. Leave OFF unless you're actively
# onboarding — it's an unauthenticated endpoint that writes 4 S3 objects
# per request and has no rate limit.
# SIGNUPS_ENABLED=true
